PORT=4000

# Kakao REST API key used by backend scripts, if needed
KAKAO_API=your_kakao_rest_api_key

# OpenAI API settings for ai-server
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Optional AI server settings
# 비워두면 프로젝트의 backend/data/app.sqlite3를 자동 사용합니다.
# FOODAI_SQLITE_PATH=C:/absolute/path/to/app.sqlite3
# 1차 LLM이 전체 프로필에서 선택할 후보 수 (10~20)
LLM_CANDIDATE_LIMIT=15
# 후보 음식점마다 2차 LLM이 확인할 실제 리뷰 수 (1~4)
RAG_REVIEWS_PER_CANDIDATE=2
CHAT_HISTORY_LIMIT=8
AI_SERVER_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
