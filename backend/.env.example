PORT=4000

# Kakao REST API key used by backend scripts, if needed
KAKAO_API=your_kakao_rest_api_key

# OpenAI API settings for ai-server
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Optional AI server settings
FOODAI_SQLITE_PATH=./backend/data/app.sqlite3
RAG_MAX_CONTEXT_ITEMS=6
CHAT_HISTORY_LIMIT=8
AI_SERVER_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
